{
  "name": "proxy-voting",
  "private": true,
  "workspaces": ["client", "server", "shared"],
  "scripts": {
    "dev": "npm run dev --workspace=server & npm run dev --workspace=client & wait",
    "db:up": "docker compose up -d",
    "db:migrate": "npm run migrate -w server",
    "db:seed": "npm run seed -w server",
    "db:studio": "npm run studio -w server",
    "demo:reset": "npm run demo:reset -w server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
